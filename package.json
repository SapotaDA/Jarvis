{
  "name": "jarvis-ai-assistant",
  "version": "2.1.0",
  "description": "Professional AI Assistant with Email, Computer Control, and Voice Capabilities",
  "main": "server/index.js",
  "homepage": "https://github.com/SapotaDA/Jarvis",
  "repository": {
    "type": "git",
    "url": "https://github.com/SapotaDA/Jarvis.git"
  },
  "bugs": {
    "url": "https://github.com/SapotaDA/Jarvis/issues"
  },
  "keywords": [
    "ai",
    "assistant",
    "jarvis",
    "voice",
    "email",
    "computer-control",
    "automation",
    "learning",
    "nodejs",
    "python",
    "ollama",
    "offline",
    "privacy"
  ],
  "author": {
    "name": "SapotaDA",
    "email": "contact@example.com",
    "url": "https://github.com/SapotaDA"
  },
  "license": "MIT",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\" \"npm run ai\"",
    "server": "cd server && npm start",
    "client": "cd client && npm run dev",
    "ai": "cd ai_services && ./venv/Scripts/python main.py",
    "test": "node test_all_features.js",
    "test:email": "node test_email_app_control.js",
    "test:voice": "node test_professional_voice.js",
    "test:features": "node test_enhanced_features.js",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && npm run build",
    "build:server": "cd server && npm run build",
    "lint": "eslint src/ server/ --ext .js,.ts,.tsx",
    "lint:fix": "eslint src/ server/ --ext .js,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{js,ts,tsx}\" \"server/**/*.{js,ts,tsx}\"",
    "clean": "npm run clean:cache && npm run clean:temp",
    "clean:cache": "rm -rf cache/*",
    "clean:temp": "rm -rf temp/*",
    "format:backend": "cd src/backend && npm run format",
    "format:frontend": "cd src/frontend && npm run format",
    "clean:backend": "cd src/backend && rm -rf dist node_modules",
    "clean:frontend": "cd src/frontend && rm -rf dist node_modules",
    "clean:ai-services": "cd src/ai-services && rm -rf venv __pycache__",
    "setup": "npm run install:all && npm run setup:ollama",
    "setup:ollama": "ollama pull qwen3.5:latest && ollama pull llama3:latest",
    "deploy": "npm run build && npm run deploy:backend && npm run deploy:frontend",
    "deploy:backend": "cd src/backend && npm run deploy",
    "deploy:frontend": "cd src/frontend && npm run deploy"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.1",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "socket.io-client": "^4.8.3",
    "express": "^4.18.2",
    "socket.io": "^4.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "better-sqlite3": "^9.2.2",
    "axios": "^1.6.7",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5"
  },
  "optionalDependencies": {
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3"
  },
  "workspaces": [
    "src/backend",
    "src/frontend",
    "src/ai-services"
  ]
}
