{
  "name": "jarvis-ai-assistant",
  "version": "2.0.0",
  "description": "Professional AI Assistant with Advanced Learning and Voice Capabilities",
  "main": "server/index.js",
  "homepage": "https://github.com/SapotaDA/Jarvis",
  "repository": {
    "type": "git",
    "url": "https://github.com/SapotaDA/Jarvis.git"
  },
  "bugs": {
    "url": "https://github.com/SapotaDA/Jarvis/issues"
  },
  "keywords": [
    "ai",
    "assistant",
    "jarvis",
    "voice",
    "learning",
    "electron",
    "nodejs",
    "python",
    "ollama",
    "offline",
    "privacy"
  ],
  "author": {
    "name": "SapotaDA",
    "email": "contact@example.com",
    "url": "https://github.com/SapotaDA"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "python": ">=3.9.0"
  },
  "scripts": {
    "install:all": "concurrently \"npm run install:backend\" \"npm run install:frontend\" \"npm run install:ai-services\"",
    "install:backend": "cd src/backend && npm install",
    "install:frontend": "cd src/frontend && npm install",
    "install:ai-services": "cd src/ai-services && python -m venv venv && venv\\Scripts\\activate && pip install -r requirements.txt",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\" \"npm run start:ai-services\"",
    "start:backend": "cd src/backend && node app.js",
    "start:frontend": "cd src/frontend && npm run dev",
    "start:ai-services": "cd src/ai-services && venv\\Scripts\\activate && python main.py",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\" \"npm run start:ai-services\"",
    "dev:backend": "cd src/backend && nodemon app.js",
    "dev:frontend": "cd src/frontend && npm run dev",
    "dev:ai-services": "cd src/ai-services && venv\\Scripts\\activate && python main.py",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd src/frontend && npm run build",
    "build:backend": "cd src/backend && npm run build",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd src/backend && npm test",
    "test:frontend": "cd src/frontend && npm test",
    "test:ai-services": "cd src/ai-services && python -m pytest",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd src/backend && npm run lint",
    "lint:frontend": "cd src/frontend && npm run lint",
    "format": "npm run format:backend && npm run format:frontend",
    "format:backend": "cd src/backend && npm run format",
    "format:frontend": "cd src/frontend && npm run format",
    "clean": "npm run clean:backend && npm run clean:frontend && npm run clean:ai-services",
    "clean:backend": "cd src/backend && rm -rf dist node_modules",
    "clean:frontend": "cd src/frontend && rm -rf dist node_modules",
    "clean:ai-services": "cd src/ai-services && rm -rf venv __pycache__",
    "setup": "npm run install:all && npm run setup:ollama",
    "setup:ollama": "ollama pull qwen3.5:latest && ollama pull llama3:latest",
    "deploy": "npm run build && npm run deploy:backend && npm run deploy:frontend",
    "deploy:backend": "cd src/backend && npm run deploy",
    "deploy:frontend": "cd src/frontend && npm run deploy"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.1",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "socket.io-client": "^4.8.3",
    "express": "^4.18.2",
    "socket.io": "^4.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "better-sqlite3": "^9.2.2",
    "axios": "^1.6.7",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5"
  },
  "optionalDependencies": {
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3"
  },
  "workspaces": [
    "src/backend",
    "src/frontend",
    "src/ai-services"
  ]
}
